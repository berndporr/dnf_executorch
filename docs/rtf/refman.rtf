93             {\cf17 const} {\cf18 int} nOutputs = (int)(method_meta->num_outputs());\par
94             std::cerr << {\cf22 "Num of outputs: "} << nOutputs << std::endl;\par
95             {\cf19 for} ({\cf18 int} i = 0; i < nOutputs; i++)\par
96             \{\par
97                 {\cf17 const} {\cf17 auto} output_meta = method_meta->output_tensor_meta(i);\par
98                 {\cf19 if} (output_meta.ok())\par
99                 \{\par
100                     std::cerr << {\cf22 "Output #"} << i << {\cf22 ":"} << std::endl;\par
101                     std::cerr << {\cf22 "Output Scalar type: "} << type_to_string(output_meta->scalar_type()) << std::endl;\par
102                     std::cerr << {\cf22 "Sizes: "};\par
103                     {\cf19 for} ({\cf17 auto} &s : output_meta->sizes())\par
104                         std::cerr << s << {\cf22 " "};\par
105                     std::cerr << std::endl;\par
106                 \}\par
107             \}\par
108 \par
109             {\cf17 auto} param = trainingNet->named_parameters({\cf22 "forward"}).get();\par
110             {\cf19 for} ({\cf17 const} {\cf17 auto} &p : param)\par
111             \{\par
112                 std::cerr << {\cf22 "Param: "} << p.first << {\cf22 " "} << p.second.numel() << {\cf22 " weights."} << std::endl;\par
113             \}\par
114         \}\par
115 \par
116         executorch::runtime::Error result = trainingNet->load_forward();\par
117         {\cf19 if} (executorch::runtime::Error::Ok != result)\par
118         \{\par
119             std::cerr << {\cf22 "load_forward() error = "} << (int)result << {\cf22 ", "} << executorch::runtime::to_string(result) << std::endl;\par
120             {\cf19 throw} result;\par
121         \}\par
122 \par
123         executorch::runtime::Error error = trainingNet->load();\par
124         {\cf19 if} (!(trainingNet->is_loaded()))\par
125         \{\par
126             std::cerr << {\cf22 "load() error = "} << (int)error << executorch::runtime::to_string(error) << std::endl;\par
127             {\cf19 throw} error;\par
128         \}\par
129 \par
130         {\cf20 // Create optimizer.}\par
131         {\cf17 auto} param_res = trainingNet->named_parameters({\cf22 "forward"});\par
132         {\cf19 if} (param_res.error() != executorch::runtime::Error::Ok)\par
133         \{\par
134             std::cerr << {\cf22 "getting parameters error = "} << (int)param_res.error()\par
135                       << executorch::runtime::to_string(param_res.error()) << std::endl;\par
136             {\cf19 throw} executorch::runtime::Error(param_res.error());\par
137         \}\par
138 \par
139         executorch::extension::training::optimizer::SGDOptions options\{learningRate\};\par
140         optimizer = std::make_shared<executorch::extension::training::optimizer::SGD>(param_res.get(), options);\par
141     \}\par
142 \par
149     {\cf18 float} filter({\cf17 const} {\cf18 float} signal, {\cf17 const} {\cf18 float} noise)\par
150     \{\par
151         {\cf17 const} {\cf18 float} delayed_signal = signal_delayLine.process(signal);\par
152         delayedSignalTensor->mutable_data_ptr<{\cf18 float}>()[0] = delayed_signal;\par
153 \par
154         noise_delayLine.process(noise);\par
155 \par
156         {\cf19 for} ({\cf18 int} i = 0; i < noiseDelayLineLength; i++)\par
157         \{\par
158             noiseTimeSeries->mutable_data_ptr<{\cf18 float}>()[i] = noise_delayLine.get(i);\par
159         \}\par
160 \par
161         {\cf17 const} {\cf17 auto} &results = trainingNet->execute_forward_backward({\cf22 "forward"}, \{noiseTimeSeries, delayedSignalTensor\});\par
162 \par
163         {\cf19 if} (results.error() != executorch::runtime::Error::Ok)\par
164         \{\par
165             fprintf(stderr, {\cf22 "Failed to execute forward_backward"});\par
166             {\cf19 return} 0;\par
167         \}\par
168         {\cf19 if} (learningIsOn)\par
169         \{\par
170             optimizer->step(trainingNet->named_gradients({\cf22 "forward"}).get());\par
171         \}\par
172 \par
173         remover = results.get()[1].toTensor().const_data_ptr<{\cf18 float}>()[0];\par
174         f_nn = delayed_signal - remover;\par
175 \par
176         {\cf19 return} f_nn;\par
177     \}\par
178 \par
183     {\cf18 void} setLearning({\cf18 bool} wants2learn = {\cf17 true})\par
184     \{\par
185         learningIsOn = wants2learn;\par
186     \}\par
187 \par
196     {\cf17 inline} {\cf18 int} getNumberOfTaps(){\cf17  const}\par
197 {\cf17     }\{\par
198         {\cf19 return} noiseDelayLineLength;\par
199     \}\par
200 \par
206     {\cf17 inline} {\cf18 int} getSignalDelaySteps(){\cf17  const}\par
207 {\cf17     }\{\par
208         {\cf19 return} signalDelayLineLength;\par
209     \}\par
210 \par
216     {\cf17 inline} {\cf18 float} getDelayedSignal(){\cf17  const}\par
217 {\cf17     }\{\par
218         {\cf19 return} signal_delayLine.get(0);\par
219     \}\par
220 \par
225     {\cf17 inline} {\cf18 float} getRemover(){\cf17  const}\par
226 {\cf17     }\{\par
227         {\cf19 return} remover;\par
228     \}\par
229 \par
235     {\cf17 inline} {\cf18 float} getOutput(){\cf17  const}\par
236 {\cf17     }\{\par
237         {\cf19 return} f_nn;\par
238     \}\par
239 \par
240 {\cf17 private}:\par
241     {\cf17 class }DelayLine\par
242     \{\par
243     {\cf17 public}:\par
244         {\cf18 void} init({\cf18 int} delay)\par
245         \{\par
246             delaySamples = delay;\par
247             buffer = std::deque<float>(delaySamples, 0.0f);\par
248         \}\par
249 \par
250         {\cf17 inline} {\cf18 float} process({\cf18 float} input)\par
251         \{\par
252             {\cf18 float} output = buffer.front();\par
253             buffer.pop_front();\par
254             buffer.push_back(input);\par
255             {\cf19 return} output;\par
256         \}\par
257 \par
258         {\cf18 float} get({\cf18 int} i){\cf17  const}\par
259 {\cf17         }\{\par
260             {\cf19 return} buffer[i];\par
261         \}\par
262 \par
263         {\cf18 float} getNewest(){\cf17  const}\par
264 {\cf17         }\{\par
265             {\cf19 return} buffer.back();\par
266         \}\par
267 \par
268     {\cf17 private}:\par
269         {\cf18 int} delaySamples = 0;\par
270         std::deque<float> buffer;\par
271     \};\par
272 \par
273     {\cf18 int} noiseDelayLineLength = 0;\par
274     {\cf18 int} signalDelayLineLength = 0;\par
275     DelayLine signal_delayLine;\par
276     DelayLine noise_delayLine;\par
277     {\cf18 float} remover = 0;\par
278     {\cf18 float} f_nn = 0;\par
279     std::shared_ptr<executorch::extension::training::TrainingModule> trainingNet;\par
280     std::shared_ptr<executorch::extension::training::optimizer::SGD> optimizer;\par
281     {\cf18 bool} learningIsOn = {\cf17 true};\par
282     executorch::extension::TensorPtr noiseTimeSeries;\par
283     executorch::extension::TensorPtr delayedSignalTensor;\par
284 \par
285     {\cf17 inline} {\cf17 const} {\cf18 char} *type_to_string(executorch::aten::ScalarType t)\par
286     \{\par
287         {\cf19 switch} (t)\par
288         \{\par
289         {\cf19 case} executorch::aten::ScalarType::Byte:\par
290             {\cf19 return} {\cf22 "Byte"};\par
291         {\cf19 case} executorch::aten::ScalarType::Char:\par
292             {\cf19 return} {\cf22 "Char"};\par
293         {\cf19 case} executorch::aten::ScalarType::Short:\par
294             {\cf19 return} {\cf22 "Short"};\par
295         {\cf19 case} executorch::aten::ScalarType::Int:\par
296             {\cf19 return} {\cf22 "Int"};\par
297         {\cf19 case} executorch::aten::ScalarType::Long:\par
298             {\cf19 return} {\cf22 "Long"};\par
299         {\cf19 case} executorch::aten::ScalarType::Float:\par
300             {\cf19 return} {\cf22 "Float"};\par
301         {\cf19 case} executorch::aten::ScalarType::Double:\par
302             {\cf19 return} {\cf22 "Double"};\par
303         {\cf19 default}:\par
304             {\cf19 return} {\cf22 "Unknown"};\par
305         \}\par
306     \}\par
307 \};\par
308 \par
309 {\cf21 #endif}\par
