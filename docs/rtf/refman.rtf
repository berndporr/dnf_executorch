49             std::move(loader_res.get()));\par
50 \par
51         std::unique_ptr<executorch::extension::FileDataLoader> ptd_loader = {\cf17 nullptr};\par
52 \par
53         trainingNet = std::make_shared<executorch::extension::training::TrainingModule>(\par
54             std::move(loader), {\cf17 nullptr}, {\cf17 nullptr}, {\cf17 nullptr}, std::move(ptd_loader));\par
55 \par
56         {\cf17 const} {\cf17 auto} method_meta = trainingNet->method_meta({\cf22 "forward"});\par
57         {\cf19 if} (!method_meta.ok())\par
58             {\cf19 throw} method_meta.error();\par
59 \par
60         {\cf17 const} {\cf17 auto} input0_meta = method_meta->input_tensor_meta(0);\par
61         noiseDelayLineLength = input0_meta->sizes()[1];\par
62         noise_delayLine.init(noiseDelayLineLength);\par
63         {\cf19 if} (debugOutput)\par
64             fprintf(stderr, {\cf22 "Noisedelayline length = %d\\n"}, noiseDelayLineLength);\par
65         noiseTimeSeries = executorch::extension::zeros(\{1, noiseDelayLineLength\});\par
66 \par
67         signalDelayLineLength = noiseDelayLineLength / 2;\par
68         signal_delayLine.init(signalDelayLineLength);\par
69         delayedSignalTensor = executorch::extension::make_tensor_ptr<float>(\{1\});\par
70         {\cf19 if} (debugOutput)\par
71             fprintf(stderr, {\cf22 "Signaldelayline length = %d\\n"}, signalDelayLineLength);\par
72 \par
73         {\cf19 if} (debugOutput)\par
74         \{\par
75             std::cerr << std::endl;\par
