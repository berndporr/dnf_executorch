41             loader_res =\par
42                 executorch::extension::FileDataLoader::from(features_pte_filename.c_str());\par
43         {\cf19 if} (loader_res.error() != executorch::runtime::Error::Ok)\par
44         \{\par
45             fprintf(stderr, {\cf22 "Failed to open model file: %s"}, features_pte_filename.c_str());\par
46             {\cf19 throw} executorch::runtime::Error(loader_res.error());\par
47         \}\par
